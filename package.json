{
  "name": "claude-sfdx-iq",
  "version": "1.3.0",
  "description": "Complete Salesforce DX plugin for Claude Code — agents, skills, hooks, commands, and rules for Apex, LWC, SOQL, Flows, and SFDX CI/CD",
  "keywords": [
    "claude-code",
    "salesforce",
    "sfdx",
    "apex",
    "lwc",
    "soql",
    "flows",
    "lightning",
    "devops",
    "agents",
    "skills",
    "hooks",
    "rules",
    "tdd",
    "code-review",
    "security",
    "governor-limits",
    "automation",
    "best-practices"
  ],
  "author": {
    "name": "Bhanu Vakati"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhanu91221/claude-sfdx-iq.git"
  },
  "homepage": "https://github.com/bhanu91221/claude-sfdx-iq#readme",
  "bugs": {
    "url": "https://github.com/bhanu91221/claude-sfdx-iq/issues"
  },
  "files": [
    "agents/",
    "commands/",
    "contexts/",
    "hooks/",
    "manifests/",
    "mcp-configs/",
    "rules/",
    "scripts/csiq.js",
    "scripts/hooks/",
    "scripts/lib/",
    "scripts/pick.js",
    "scripts/tokens.js",
    "scripts/refresh-claude-md.js",
    "scripts/estimate-tokens.js",
    "scripts/doctor.js",
    "scripts/status.js",
    "scripts/install-apply.js",
    "scripts/install-plan.js",
    "scripts/list-installed.js",
    "scripts/repair.js",
    "scripts/setup-project.js",
    "skills/",
    "AGENTS.md",
    ".claude-plugin/plugin.json",
    ".claude-project-template/"
  ],
  "bin": {
    "claude-sfdx-iq": "scripts/csiq.js",
    "claude-sfdx-iq-setup": "scripts/setup-project.js"
  },
  "scripts": {
    "lint": "eslint . && markdownlint **/*.md --ignore node_modules",
    "test": "node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node scripts/ci/validate-install-manifests.js && node tests/run-all.js",
    "coverage": "c8 --all --include=\"scripts/**/*.js\" --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --reporter=text --reporter=lcov node tests/run-all.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "ajv": "^8.12.0",
    "c8": "^9.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "markdownlint-cli": "^0.39.0"
  },
  "engines": {
    "node": ">=18"
  }
}
