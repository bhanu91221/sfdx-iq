{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Plugin Definition",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "minLength": 1 },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "author": { "type": "string" },
    "license": { "type": "string" }
  }
}
